# .env template for Docker Compose deployment
# Copy this file to .env and fill in your actual values

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# JWT Configuration (IMPORTANT: Generate new secret!)
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-production-jwt-secret-min-32-characters
JWT_EXPIRE=7d

# Frontend Configuration
FRONTEND_URL=https://your-domain.com
BACKEND_URL=https://api.your-domain.com
DEVICE_SERVER_WS_URL=wss://device.your-domain.com

# Device Server Configuration
DEVICE_SERVER_HOST=your-vps-ip.com
DEVICE_SERVER_PORT=4370

# Node Environment
NODE_ENV=production
